# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MAX_TOKENS=65536
DEEPSEEK_REASONING_EFFORT=max
DEEPSEEK_THINKING=true
# Per-request HTTP timeout for chat/completions (seconds)
DEEPSEEK_TIMEOUT=300
# Overall LangGraph agent run budget (seconds; multi-round tools + LLM)
AGENT_RUN_TIMEOUT=900
# Default news poll crontab (5 fields, APP_TIMEZONE). Editable on Jobs page.
# 0 8-22/2 * * * → every 2 hours from 08:00–22:00
NEWS_CRONTAB=0 8-22/2 * * *

# Display timezone for UI / logs (DB stays UTC). Default Beijing.
APP_TIMEZONE=Asia/Shanghai

# Public access password gate (set AUTH_ENABLED=true before exposing to the internet)
AUTH_ENABLED=false
AUTH_PASSWORD=
AUTH_MAX_FAILURES=3

# Telegram (optional — leave empty to disable notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
